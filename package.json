{
  "name": "solid-nui",
  "version": "0.9.0",
  "description": "Type-safe NUI communication utilities built for SolidJS",
  "license": "LGPL-3.0-or-later",
  "author": "Filipe Junqueiro",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/filipejunqueiro/solid-nui.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "happy-dom": "^20.8.9",
    "solid-js": "^1.9.12",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  },
  "peerDependencies": {
    "solid-js": "^1.9.12"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
